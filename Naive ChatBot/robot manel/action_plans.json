{
    "PICK_PLACE": {
        "description": "Pick up, move, or place an object",
        "steps": [
            "identify_target_object",
            "plan_approach_trajectory",
            "open_gripper",
            "approach_object",
            "close_gripper",
            "lift_object",
            "transport_to_destination",
            "place_object",
            "open_gripper",
            "retract_arm"
        ],
        "safety_notes": "Verify object weight within gripper capacity before lifting"
    },
    "CUT": {
        "description": "Cut, saw, or trim a piece of wood",
        "steps": [
            "verify_workpiece_clamped",
            "select_cutting_tool",
            "measure_cut_position",
            "align_cutting_tool",
            "activate_dust_extraction",
            "execute_cut",
            "deactivate_tool",
            "verify_cut_quality",
            "remove_offcut"
        ],
        "safety_notes": "Ensure workpiece is securely clamped. Verify guard is in place."
    },
    "DRILL": {
        "description": "Drill or bore a hole in a workpiece",
        "steps": [
            "verify_workpiece_clamped",
            "select_drill_bit",
            "mark_drill_position",
            "set_drill_depth",
            "align_drill",
            "activate_drill",
            "drill_to_depth",
            "retract_drill",
            "deactivate_drill",
            "clear_debris"
        ],
        "safety_notes": "Use backing board to prevent tearout. Wear eye protection."
    },
    "SAND": {
        "description": "Sand or smooth a wood surface",
        "steps": [
            "verify_workpiece_secured",
            "select_sandpaper_grit",
            "attach_sandpaper_to_sander",
            "activate_dust_extraction",
